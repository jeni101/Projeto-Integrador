# PHorta Dashboard — environment reference
#
# No Vercel environment variables are required to deploy this static dashboard.
# API endpoints are hardcoded in src/services/apiService.js:
#
#   PRIMARY_API =https://horta-api-htggarb3eagagpgm.brazilsouth-01.azurewebsites.net
#   FALLBACK_API=https://server-horta.onrender.com
#
# External services (not hosted on Vercel):
#   - Azure App Service — primary REST API
#   - Render — fallback REST API
#   - ESP32 firmware, MQTT broker, InfluxDB/PostgreSQL — IoT backend stack
#
# To point the dashboard at different APIs, edit PRIMARY_API / FALLBACK_API
# in src/services/apiService.js and redeploy.
